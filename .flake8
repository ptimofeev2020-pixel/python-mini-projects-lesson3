[flake8]
# Максимальная длина строки — совпадает с настройкой black
max-line-length = 119

# Коды, которые игнорируются:
#   E203 — пробел перед ':' (black расставляет так при срезах)
#   W503 — перенос строки перед бинарным оператором (PEP 8 разрешает оба стиля)
#   E501 — длина строки контролируется через max-line-length выше
extend-ignore = E203, W503, E501

# Директории и файлы, которые Flake8 не проверяет
exclude =
    .git,
    __pycache__,
    .mypy_cache,
    .venv,
    .env,
    venv,
    dist,
    build,
    *.egg-info,
    .idea,
    migrations

# Проверяемые пакеты/папки (явно задаём src и tests)
per-file-ignores =
    # В __init__.py допускаем неиспользуемые импорты (F401),
    # т.к. они часто служат для экспорта API пакета
    __init__.py: F401
    # В тестах допускаем assert и "магические" значения
    tests/*: S101, S105, S106

# Максимальная сложность функции (цикломатическая)
max-complexity = 10

# Отображать статистику в конце вывода
statistics = True
count = True
